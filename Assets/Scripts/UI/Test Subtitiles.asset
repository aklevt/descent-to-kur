  m_EditorClassIdentifier: GameScripts::UI.DialogueData
  lines:
  - text: "\u042D\u0442\u043E \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
      \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u044B\u043C \u0442\u0435\u043A\u0441\u0442\u043E\u043C,
      \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043C, \u0432 Intro"
    speakerName: 
    speakerPortrait: {fileID: -5621593187482372676, guid: c8e0430e86ea84e4290e948b661302f1, type: 3}
    delayAfter: 0.5
  - text: "\u0415\u0449\u0435 \u043E\u0434\u043D\u0430 \u0441\u0442\u0440\u043E\u043A\u0430
      \u0442\u0435\u043A\u0441\u0442\u0430. \u0415\u0449\u0435 \u043E\u0434\u043D\u0430
      \u0441\u0442\u0440\u043E\u043A\u0430 \u0442\u0435\u043A\u0441\u0442\u0430.
      \u0415\u0449\u0435 \u043E\u0434\u043D\u0430 \u0441\u0442\u0440\u043E\u043A\u0430
      \u0442\u0435\u043A\u0441\u0442\u0430. \u0415\u0449\u0435 \u043E\u0434\u043D\u0430
      \u0441\u0442\u0440\u043E\u043A\u0430 \u0442\u0435\u043A\u0441\u0442\u0430.
      \u0415\u0449\u0435 \u043E\u0434\u043D\u0430 \u0441\u0442\u0440\u043E\u043A\u0430
      \u0442\u0435\u043A\u0441\u0442\u0430."
    speakerName: "\u0418\u0433\u0440\u043E\u043A"
    speakerPortrait: {fileID: -2311659948842064771, guid: f9f8b894730c3bc418d072ad5f9f608e, type: 3}
